# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Application Configuration
DEBUG=True
LOG_LEVEL=INFO

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Processing Configuration
MAX_RETRIES=3
PREFETCH_COUNT=1
RETRY_DELAY=10000
